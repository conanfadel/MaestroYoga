APP_ENV=staging
APP_NAME=MaestroYoga-Staging
COOKIE_SECURE=1
SHOW_DEV_VERIFY_LINK=0
PUBLIC_REQUIRE_EMAIL_VERIFICATION=1
PUBLIC_BASE_URL=https://staging.your-domain.com

DATABASE_URL=postgresql+psycopg2://maestro:change-me@localhost:5432/maestroyoga_staging

JWT_SECRET=replace-with-long-random-secret-1
PUBLIC_JWT_SECRET=replace-with-long-random-secret-2
JWT_EXPIRES_MINUTES=120
PUBLIC_SESSION_EXPIRES_MINUTES=10080
PUBLIC_EMAIL_VERIFY_EXPIRES_MINUTES=30
PUBLIC_PASSWORD_RESET_EXPIRES_MINUTES=30
SEED_DEMO_KEY=replace-with-long-random-secret-3

PAYMENT_PROVIDER=mock

MAIL_PROVIDER=smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@your-domain.com
SMTP_SECURITY=starttls
MAILER_DELIVERY_MODE=sync
MAILER_ASYNC_WORKERS=2

RATE_LIMIT_BACKEND=memory
RATE_LIMIT_PREFIX=maestroyoga:rl:staging
RATE_LIMIT_MAX_LOCKOUT_SECONDS=900
