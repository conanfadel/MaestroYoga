DATABASE_URL=sqlite:///./maestro_yoga.db
# text (default) | json — json = سطر JSON لكل رسالة (مناسب للمراقبة والتجميع)
# LOG_FORMAT=json
# LOG_LEVEL=INFO
# تتبع الأخطاء (اختياري): أنشئ مشروعًا في sentry.io والصق DSN
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
JWT_SECRET=change-this-in-production
JWT_EXPIRES_MINUTES=120
# مدة صلاحية refresh token للموظفين (بالدقائق؛ افتراضي 30 يومًا)
# JWT_REFRESH_EXPIRES_MINUTES=43200
PUBLIC_JWT_SECRET=change-this-in-production-too
PUBLIC_SESSION_EXPIRES_MINUTES=10080
PUBLIC_EMAIL_VERIFY_EXPIRES_MINUTES=30
PUBLIC_PASSWORD_RESET_EXPIRES_MINUTES=30
PUBLIC_REQUIRE_EMAIL_VERIFICATION=1
# جدول الجلسات العام: أيام للوراء في الاستعلام قبل تصفية المنتهية (0–30، افتراضي 2).
# PUBLIC_SESSION_LIST_LOOKBACK_DAYS=2

# إلزامي في الإنتاج: الرابط العام للموقع (https) ليصبح رابط التحقق في البريد صحيحًا
# PUBLIC_BASE_URL=https://app.example.com
PUBLIC_BASE_URL=

# Real SMTP settings (required for actual verification/reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURITY=starttls
MAILER_ASYNC_WORKERS=2
APP_NAME=Maestro Yoga
SHOW_DEV_VERIFY_LINK=0
MAIL_PROVIDER=smtp
# MAIL_PROVIDER=apps_script
# MAIL_RELAY_URL=https://script.google.com/macros/s/xxx/exec
# MAIL_RELAY_TOKEN=change-this-in-production
MAILER_DELIVERY_MODE=sync
# تعطيل بريد «تأكيد بعد الدفع» (افتراضي مفعّل عند ضبط البريد): DISABLE_PAYMENT_SUCCESS_EMAIL=1
GA4_MEASUREMENT_ID=
STRIPE_CHECKOUT_ALLOWED_ORIGINS=

# Proxy IP handling (enable only behind trusted reverse proxy)
TRUST_PROXY_HEADERS=0
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Domain authentication (recommended in production)
MAIL_DOMAIN=example.com
MAIL_DKIM_SELECTOR=maestro

# Enterprise rate limiting
# auto | memory | redis
RATE_LIMIT_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PREFIX=maestroyoga:rl
RATE_LIMIT_MAX_LOCKOUT_SECONDS=900

# Security audit logging
SECURITY_AUDIT_LOG_FILE=logs/security_audit.log
SECURITY_AUDIT_LOG_MAX_BYTES=2097152
SECURITY_AUDIT_LOG_BACKUPS=5
SECURITY_AUDIT_ASYNC=0
SECURITY_AUDIT_ASYNC_WORKERS=1

# mock | stripe | paymob
PAYMENT_PROVIDER=mock

# Hosted checkout never completed: cancel pending_payment bookings after N minutes (background sweeper).
# PENDING_PAYMENT_EXPIRE_MINUTES=180
# STALE_PAYMENT_SWEEP_INTERVAL_SEC=900
# DISABLE_STALE_PAYMENT_SWEEPER=0
# PAYMENT_RECONCILE_INTERVAL_SEC=300
# PAYMENT_RECONCILE_OLDER_THAN_MINUTES=5
# DISABLE_PAYMENT_RECONCILE=0
# PAYMENT_WEBHOOK_DELAY_MONITOR_INTERVAL_SEC=600
# PAYMENT_WEBHOOK_DELAY_MINUTES=10
# DISABLE_WEBHOOK_DELAY_MONITOR=0
# OPS_PENDING_OVERDUE_ALERT_THRESHOLD=5
# OPS_ALERT_COOLDOWN_SEC=900
# OPS_ALERT_WEBHOOK_URL=
# OPS_ALERT_WEBHOOK_TOKEN=
# SUBSCRIPTION_EXPIRY_SWEEP_INTERVAL_SEC=900
# DISABLE_SUBSCRIPTION_EXPIRY_SWEEPER=0

# Paymob Accept (when PAYMENT_PROVIDER=paymob). عناوين API حسب الدولة: accept.paymob.com (مصر)، ksa.paymob.com (السعودية)، …
# من لوحة Paymob (API Key / Secret Key / Public Key / HMAC):
#   — التوثيق في الخادم: عيّن PAYMOB_API_KEY **أو** PAYMOB_SECRET_KEY (واحد فقط يكفي؛ يُرسل كـ api_key لـ /api/auth/tokens).
#   — التحقق من Webhook: PAYMOB_HMAC_SECRET **أو** PAYMOB_HMAC (نفس قيمة «HMAC» في اللوحة).
#   — Public Key: للتكامل من المتصفح (Pixel وغيره)؛ مسار iframe الحالي لا يستخدمه في الخادم.
# معرف التكامل (غالباً Developers → Payment Integrations → Online Card):
# PAYMOB_INTEGRATION_ID=   (أو PAYMOB_CARD_INTEGRATION_ID)
# Apple Pay (تكامل رقمي منفصل في اللوحة): عند التفعيل يُمرَّر هذا الرقم في payment_keys بدل البطاقة.
# أبقِ PAYMOB_INTEGRATION_ID للبطاقة إن أردت التبديل لاحقاً؛ انسخ من اللوحة رابط/Iframe الخاص بـ Apple Pay إلى PAYMOB_IFRAME_LINK إن كان مختلفاً.
# PAYMOB_USE_APPLE_PAY_INTEGRATION=1
# PAYMOB_APPLE_PAY_INTEGRATION_ID=
# رابط واجهة الدفع من لوحة Paymob («Iframe Link») — الصق الرابط كاملاً بدون payment_token، أو وسم iframe فقط:
# PAYMOB_IFRAME_LINK=
# أو نفس المعنى: PAYMOB_IFRAME_CHECKOUT_BASE=
# PAYMOB_IFRAME_ID=   (اختياري إن لم تستخدم الرابط أعلاه؛ إن تركتها فارغة يُستخدم رقم التكامل في المسار الافتراضي)
# PAYMOB_API_BASE=https://accept.paymob.com
# PAYMOB_API_KEY=
# PAYMOB_SECRET_KEY=
# PAYMOB_HMAC_SECRET=
# PAYMOB_HMAC=
# Webhook في لوحة Paymob: POST https://<PUBLIC_BASE_URL>/payments/webhook/paymob
# PAYMOB_SKIP_REDIRECTION_URL=1  (اختياري: إن فشل إنشاء payment_key بسبب redirection_url)
# PAYMOB_BILLING_EMAIL=
# PAYMOB_BILLING_PHONE=

# Stripe (required only when PAYMENT_PROVIDER=stripe)
# لحساب Stripe في السعودية: بطاقات مدى تُقبل عبر نموذج البطاقة في Checkout (راجع توثيق Stripe / mada).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# في لوحة Stripe → Webhooks أضف أحداثاً إضافية عند الحاجة: charge.refunded، charge.dispute.created (إلى جانب checkout.session.completed / expired).
# واجهة الدفع: auto | ar | en (للعربية في صفحة Stripe استخدم ar)
STRIPE_CHECKOUT_LOCALE=auto

# تهيئة ديمو من جهاز بعيد: عيّن مفتاحًا عشوائيًا قويًا وأرسله كـ X-Seed-Demo-Key
# SEED_DEMO_KEY=
