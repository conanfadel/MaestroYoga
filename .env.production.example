APP_ENV=production
APP_NAME=MaestroYoga
COOKIE_SECURE=1
SHOW_DEV_VERIFY_LINK=0
PUBLIC_REQUIRE_EMAIL_VERIFICATION=1
PUBLIC_BASE_URL=https://your-domain.com

DATABASE_URL=postgresql+psycopg2://maestro:change-me@db:5432/maestroyoga

JWT_SECRET=replace-with-long-random-secret-1
PUBLIC_JWT_SECRET=replace-with-long-random-secret-2
JWT_EXPIRES_MINUTES=120
PUBLIC_SESSION_EXPIRES_MINUTES=10080
PUBLIC_EMAIL_VERIFY_EXPIRES_MINUTES=30
PUBLIC_PASSWORD_RESET_EXPIRES_MINUTES=30
SEED_DEMO_KEY=replace-with-long-random-secret-3

PAYMENT_PROVIDER=mock
# للدفع الحقيقي عبر Stripe (يشمل مدى في السعودية): PAYMENT_PROVIDER=stripe + STRIPE_* + STRIPE_CHECKOUT_LOCALE=ar
# STRIPE_CHECKOUT_LOCALE=ar
# للدفع عبر Paymob: PAYMENT_PROVIDER=paymob + (PAYMOB_API_KEY أو PAYMOB_SECRET_KEY) + PAYMOB_INTEGRATION_ID + PAYMOB_IFRAME_ID + (PAYMOB_HMAC_SECRET أو PAYMOB_HMAC)
# PAYMOB_API_BASE=https://accept.paymob.com  (أو https://ksa.paymob.com حسب الحساب)
# PAYMOB_API_KEY=
# PAYMOB_SECRET_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_IFRAME_ID=
# PAYMOB_HMAC_SECRET=
# PAYMOB_HMAC=
# Webhook في لوحة Paymob: https://your-domain.com/payments/webhook/paymob

# Choose one mail provider:
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=no-reply@your-domain.com
# SMTP_SECURITY=starttls

# MAIL_PROVIDER=apps_script
# MAIL_RELAY_URL=https://script.google.com/macros/s/xxx/exec
# MAIL_RELAY_TOKEN=replace-with-long-random-secret-4
# SMTP_FROM=no-reply@your-domain.com

MAILER_DELIVERY_MODE=sync
MAILER_ASYNC_WORKERS=2

RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_PREFIX=maestroyoga:rl
RATE_LIMIT_MAX_LOCKOUT_SECONDS=900
